# Simplified API-only Dockerfile
FROM node:20-alpine

# Install dependencies
RUN apk add --no-cache jemalloc curl
ENV LD_PRELOAD=/usr/lib/libjemalloc.so.2

WORKDIR /app

# Copy package files
COPY package*.json ./
COPY packages/data-provider/package*.json ./packages/data-provider/
COPY packages/mcp/package*.json ./packages/mcp/
COPY packages/data-schemas/package*.json ./packages/data-schemas/
COPY api/package*.json ./api/

# Install production dependencies
RUN npm ci --omit=dev --legacy-peer-deps

# Copy built packages from host
COPY packages/data-provider/dist ./packages/data-provider/dist
COPY packages/mcp/dist ./packages/mcp/dist
COPY packages/data-schemas/dist ./packages/data-schemas/dist

# Copy API code
COPY api ./api
COPY config ./config
COPY librechat.yaml ./librechat.yaml

# Expose port
EXPOSE 3080

# Set environment
ENV HOST=0.0.0.0

# Start the API
CMD ["npm", "run", "backend"]