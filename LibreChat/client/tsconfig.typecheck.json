{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": true,
    "skipLibCheck": true
  },
  "include": [
    "src/**/*",
    "env.d.ts",
    "../config/translations/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "vite.config.ts",
    "test/**/*",
    "src/**/*.test.*",
    "src/**/*.spec.*",
    "src/**/__tests__/**/*",
    "../e2e/**/*"
  ]
}