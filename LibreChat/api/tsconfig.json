{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "node",
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "strict": true,
    "strictNullChecks": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": false,
    "outDir": "./dist",
    "rootDir": "./",
    "baseUrl": "./",
    "paths": {
      "#*": ["./*"],
      "#config/*": ["./config/*"],
      "#models/*": ["./models/*"],
      "#server/*": ["./server/*"],
      "#utils/*": ["./utils/*"],
      "#lib/*": ["./lib/*"],
      "#strategies/*": ["./strategies/*"],
      "#app/*": ["./app/*"],
      "#cache/*": ["./cache/*"]
    }
  },
  "include": [
    "**/*.js",
    "**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "test",
    "logs"
  ]
}