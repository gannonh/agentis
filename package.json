{
  "name": "agentis",
  "version": "0.0.1",
  "private": true,
  "license": "MIT",
  "scripts": {
    "build": "turbo build",
    "ci": "pnpm lint && pnpm test:coverage && pnpm test:e2e",
    "dev": "turbo dev",
    "lint": "turbo lint",
    "format": "turbo format",
    "prepare": "husky",
    "test": "turbo test",
    "test:coverage": "turbo test:coverage",
    "test:e2e": "pnpm --filter web build && playwright test",
    "typecheck": "turbo typecheck",
    "support-agent:worker:dev": "pnpm --filter web support-agent:worker:dev",
    "support-agent:worker:check": "pnpm --filter web support-agent:worker:check",
    "support-agent:worker:deploy": "pnpm --filter web support-agent:worker:deploy",
    "support-agent:worker:acceptance": "pnpm --filter web support-agent:worker:acceptance",
    "support-agent:worker:delete": "pnpm --filter web support-agent:worker:delete",
    "support-agent:access-token": "pnpm --filter web support-agent:access-token"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "husky": "^9.1.7",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "turbo": "^2.8.17",
    "typescript": "5.9.3"
  },
  "packageManager": "pnpm@9.15.9",
  "engines": {
    "node": ">=22"
  }
}
