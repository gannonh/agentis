# Prefer the repo root .env (../../.env) for OPENAI_API_KEY and shared secrets.
# Copy from ../../.env.example, or use this file for API-only overrides.

# SQLite database file path (relative to apps/api when running pnpm dev)
DATABASE_URL=./data/agentis.db

# API listen port
PORT=3001

# Set to 1 for local E2E/CI without OpenAI (mock streaming runtime)
# AGENTIS_MOCK_RUNTIME=1
