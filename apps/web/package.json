{
  "name": "web",
  "version": "0.0.1",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint",
    "format": "prettier --write \"**/*.{ts,tsx}\"",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit -p tsconfig.app.json && tsc --noEmit -p tsconfig.node.json && tsc --noEmit -p tsconfig.test.json",
    "support-agent:eval": "tsx scripts/support-agent-eval.mjs",
    "support-agent:deploy:preview": "tsx scripts/support-agent-preview-deploy.mjs",
    "support-agent:deploy:worker:preview": "wrangler deploy --env preview --config wrangler.toml",
    "preview": "vite preview"
  },
  "dependencies": {
    "@ai-sdk/openai": "^3.0.63",
    "@phosphor-icons/react": "^2.1.10",
    "@workspace/ui": "workspace:*",
    "ai": "^6.0.182",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@tailwindcss/vite": "^4.1.18",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^25.1.0",
    "@types/react": "^19.2.10",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "@vitest/coverage-v8": "^4.1.5",
    "eslint": "^9.39.2",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^17.2.0",
    "jsdom": "^29.1.1",
    "tsx": "^4.22.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.54.0",
    "vite": "^7.3.2",
    "vitest": "^4.1.5",
    "wrangler": "^4.92.0"
  }
}
