# Monorepo environment (loaded by apps/api on startup)
OPENAI_API_KEY=

# Composio integrations (server-only; never expose to the web app)
# COMPOSIO_API_KEY=
# Agentis reserves a local dev port pair to avoid collisions with other projects.
# AGENTIS_API_PORT=3101
# AGENTIS_WEB_PORT=5177
# Public URL of the API (for Composio OAuth return). Local dev:
# COMPOSIO_REDIRECT_BASE_URL=http://127.0.0.1:3101
# Web app URL for post-auth redirect (match your Vite port):
# AGENTIS_WEB_ORIGIN=http://127.0.0.1:5177
# Optional explicit Vite proxy target:
# VITE_API_PROXY_TARGET=http://127.0.0.1:3101
# COMPOSIO_USER_ID=agentis-local-user
# Optional overrides; defaults are baked in for featured toolkits when unset.
# COMPOSIO_TOOLKIT_VERSIONS={"github":"20260501_01"}
# AGENTIS_MOCK_COMPOSIO=1
# For live Composio during daily dev, use AGENTIS_MOCK_COMPOSIO=0 (or run: pnpm dev:live).
# E2E tests set AGENTIS_E2E=1 so Playwright mock env is not overridden by .env.

# Optional API overrides. Prefer AGENTIS_API_PORT over generic PORT.
# PORT=3101
# DATABASE_URL=./apps/api/data/agentis.db
# AGENTIS_MOCK_RUNTIME=1
# Enable local debug seed routes. Use only in local/dev workspaces.
# AGENTIS_DEBUG_SEED_KEY=change-me-local-debug-key
# VITE_AGENTIS_DEBUG_SEED_KEY=change-me-local-debug-key

# Local artifact storage (server-only)
# AGENTIS_STORAGE_ROOT=./data/storage
# AGENTIS_ARTIFACT_MAX_UPLOAD_BYTES=10485760
# AGENTIS_ARTIFACT_PREVIEW_MAX_CHARS=2000
# AGENTIS_PROJECT_GOALS_MAX_CHARS=4000
# AGENTIS_PROJECT_MEMORY_MAX_CHARS=2000
