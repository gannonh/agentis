# Agentis environment reference (repo root)
#
# Local development: copy to `.env` and fill in values.
# Cursor Cloud Agents: do NOT create a repo `.env` with secrets or mock flags.
# Configure runtime credentials in the Cursor Cloud console instead; the VM injects
# them into process.env and a local `.env` can override or shadow those values.

# Runtime keys
# COMPOSIO_API_KEY=
# COMPOSIO_REDIRECT_BASE_URL=http://127.0.0.1:3101
# AGENTIS_MOCK_COMPOSIO=0
# AGENTIS_MOCK_RUNTIME=0

# Projects, context, and artifacts (server-only)
# AGENTIS_STORAGE_ROOT=./data/storage
# AGENTIS_ARTIFACT_MAX_UPLOAD_BYTES=10485760
# AGENTIS_ARTIFACT_PREVIEW_MAX_CHARS=2000
# AGENTIS_DOCUMENT_MAX_UPLOAD_BYTES=10485760
# AGENTIS_DOCUMENT_PREVIEW_MAX_CHARS=2000
# AGENTIS_PROJECT_GOALS_MAX_CHARS=4000
# AGENTIS_PROJECT_MEMORY_MAX_CHARS=2000

# Agentis reserved local dev ports
# AGENTIS_API_PORT=3101
# AGENTIS_WEB_PORT=5177
# AGENTIS_WEB_ORIGIN=http://127.0.0.1:5177
# VITE_API_PROXY_TARGET=http://127.0.0.1:3101

# AI Gateway config
# AI_GATEWAY_PROVIDER=cloudflare
# AI_GATEWAY_PROVIDER=vercel
# SUPPORT_AGENT_MODEL=gpt-5.4-mini

# AI Gateway secrets
# VERCEL_AI_GATEWAY_API_KEY=
# AI_GATEWAY_API_KEY=
# CLOUDFLARE_API_KEY=
# CLOUDFLARE_ACCOUNT_ID=
# CLOUDFLARE_AI_GATEWAY_ID=default

# Native web search config
# AGENTIS_WEB_SEARCH_PROVIDER=tavily
# AGENTIS_WEB_SEARCH_PROVIDER=vercel-gateway
# AGENTIS_WEB_SEARCH_BACKEND=keyless
# AGENTIS_WEB_SEARCH_BACKEND=perplexity
# AGENTIS_WEB_SEARCH_BACKEND=parallel
# AGENTIS_WEB_SEARCH_MAX_RESULTS=5
# AGENTIS_WEB_SEARCH_MAX_SNIPPET_CHARS=500

# Optional API overrides
# DATABASE_URL=./apps/api/data/agentis.db
# COMPOSIO_USER_ID=agentis-local-user
# COMPOSIO_TOOLKIT_VERSIONS={"github":"20260501_01"}

# Invocation worker (scheduled agent runs)
# AGENTIS_WORKER_POLL_MS=60000

# Webhook invocation
# AGENTIS_API_PUBLIC_ORIGIN=http://127.0.0.1:3101
# AGENTIS_WEBHOOK_SECRET_KEY=
# AGENTIS_WEBHOOK_REPLAY_WINDOW_SECONDS=300
# AGENTIS_WEBHOOK_MAX_PAYLOAD_BYTES=65536

# Sandboxed workspace command/script execution
# AGENTIS_SANDBOX_BACKEND=local-process
# AGENTIS_SANDBOX_BACKEND=local-container
# AGENTIS_SANDBOX_TIMEOUT_MS=30000
# AGENTIS_SANDBOX_MAX_STDOUT_BYTES=65536
# AGENTIS_SANDBOX_MAX_STDERR_BYTES=65536
# AGENTIS_SANDBOX_CHANGED_FILES_LIMIT=50
# AGENTIS_SANDBOX_COMMAND_DENY_PATTERNS=
# AGENTIS_SANDBOX_CONTAINER_IMAGE=agentis-sandbox:local

# E2E tests set AGENTIS_E2E=1 so Playwright mock env is not overridden by .env.
