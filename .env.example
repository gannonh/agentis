# Monorepo environment (loaded by apps/api on startup)
OPENAI_API_KEY=

# Composio integrations (server-only; never expose to the web app)
# COMPOSIO_API_KEY=
# Agentis reserves a local dev port pair to avoid collisions with other projects.
# AGENTIS_API_PORT=3101
# AGENTIS_WEB_PORT=5177
# Public URL of the API (for Composio OAuth return). Local dev:
# COMPOSIO_REDIRECT_BASE_URL=http://127.0.0.1:3101
# Web app URL for post-auth redirect (match your Vite port):
# AGENTIS_WEB_ORIGIN=http://127.0.0.1:5177
# Optional explicit Vite proxy target:
# VITE_API_PROXY_TARGET=http://127.0.0.1:3101
# COMPOSIO_USER_ID=agentis-local-user
# Optional overrides; defaults are baked in for featured toolkits when unset.
# COMPOSIO_TOOLKIT_VERSIONS={"github":"20260501_01"}
# AGENTIS_MOCK_COMPOSIO=1
# For live Composio during daily dev, use AGENTIS_MOCK_COMPOSIO=0 (or run: pnpm dev:live).
# E2E tests set AGENTIS_E2E=1 so Playwright mock env is not overridden by .env.

# Optional API overrides. Prefer AGENTIS_API_PORT over generic PORT.
# PORT=3101
# DATABASE_URL=./apps/api/data/agentis.db
# AGENTIS_MOCK_RUNTIME=1

# Native web search. The default vercel-gateway provider requires AI Gateway
# credentials when an agent is permitted to use Search.
# AI_GATEWAY_API_KEY=
# AGENTIS_WEB_SEARCH_PROVIDER=vercel-gateway
# AGENTIS_WEB_SEARCH_BACKEND=perplexity
# AGENTIS_WEB_SEARCH_MAX_RESULTS=5
# AGENTIS_WEB_SEARCH_MAX_SNIPPET_CHARS=500

# Local artifact storage (server-only)
# AGENTIS_STORAGE_ROOT=./data/storage
# AGENTIS_ARTIFACT_MAX_UPLOAD_BYTES=10485760
# AGENTIS_ARTIFACT_PREVIEW_MAX_CHARS=2000
# AGENTIS_PROJECT_GOALS_MAX_CHARS=4000
# AGENTIS_PROJECT_MEMORY_MAX_CHARS=2000
# AGENTIS_WORKSPACE_WRITE_MAX_BYTES=262144
# Optional: AGENTIS_WORKSPACE_WRITE_DENY_PREFIXES=.env,.git

# Sandboxed workspace command/script execution. Production defaults to
# local-container when unset; development/test default to local-process.
# local-process preserves the current host-process dev behavior.
# local-container uses a Docker-compatible runtime through the standard docker
# CLI/socket. Docker Desktop and OrbStack are compatible examples. ArcBox is
# future-watch/experimental only and is not a supported local-container runtime.
# AGENTIS_SANDBOX_BACKEND=local-container
# AGENTIS_SANDBOX_TIMEOUT_MS=30000
# AGENTIS_SANDBOX_MAX_STDOUT_BYTES=65536
# AGENTIS_SANDBOX_MAX_STDERR_BYTES=65536
# AGENTIS_SANDBOX_CHANGED_FILES_LIMIT=50
# Optional comma-separated command substring deny list.
# AGENTIS_SANDBOX_COMMAND_DENY_PATTERNS=
# Used when AGENTIS_SANDBOX_BACKEND=local-container. Build and smoke test with:
# pnpm smoke:sandbox-container
# AGENTIS_SANDBOX_CONTAINER_IMAGE=agentis-sandbox:local
